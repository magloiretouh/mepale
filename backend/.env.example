# MEPALE ERP — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=remplacer-par-une-cle-secrete-longue-et-aleatoire

# PostgreSQL
DB_NAME=mepale_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379

# CORS (séparés par virgule)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173

# Email (production uniquement)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@mepale.tg
